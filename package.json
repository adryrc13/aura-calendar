{
  "name": "aura-calendar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:internal": "node scripts/run-internal-tests.cjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "android:build:web": "npm run build",
    "android:sync": "npm run build && cap sync android",
    "android:assemble:debug": "cd android && gradlew.bat assembleDebug",
    "android:assemble:release": "cd android && gradlew.bat assembleRelease",
    "android:bundle:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capgo/capacitor-speech-recognition": "^8.1.7",
    "@supabase/supabase-js": "^2.108.1",
    "dexie": "^4.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
